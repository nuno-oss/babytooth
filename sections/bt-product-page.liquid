<script>
(function() {
  var sid = '{{ section.id }}';

  /* ── Thumbnail gallery swap ── */
  var mainImg = document.getElementById('bt-pd-main-img-' + sid);
  var thumbs = document.querySelectorAll('#bt-pd-' + sid + ' .bt-pd-gallery__thumb');
  thumbs.forEach(function(thumb) {
    thumb.addEventListener('click', function() {
      var src = this.getAttribute('data-src');
      if (src && mainImg) { mainImg.src = src; }
      thumbs.forEach(function(t) { t.classList.remove('bt-pd-active'); });
      this.classList.add('bt-pd-active');
    });
  });

  /* ── Variant pill toggles ── */
  var variantGroups = document.querySelectorAll('#bt-pd-' + sid + ' .bt-pd-variants');
  variantGroups.forEach(function(group) {
    group.querySelectorAll('.bt-pd-variant-btn').forEach(function(btn) {
      btn.addEventListener('click', function() {
        group.querySelectorAll('.bt-pd-variant-btn').forEach(function(b) {
          b.classList.remove('bt-pd-active');
        });
        this.classList.add('bt-pd-active');
      });
    });
  });

  /* ── FAQ accordion ── */
  var faqItems = document.querySelectorAll('#bt-pd-' + sid + ' .bt-pd-faq__item');
  faqItems.forEach(function(item) {
    item.querySelector('.bt-pd-faq__q').addEventListener('click', function() {
      var isOpen = item.classList.contains('bt-pd-open');
      faqItems.forEach(function(i) { i.classList.remove('bt-pd-open'); });
      if (!isOpen) { item.classList.add('bt-pd-open'); }
    });
  });

  /* ── Review carousel ── */
  var carousel = document.getElementById('bt-pd-carousel-' + sid);
  var prevBtn = document.getElementById('bt-pd-prev-' + sid);
  var nextBtn = document.getElementById('bt-pd-next-' + sid);
  if (carousel && prevBtn && nextBtn) {
    var current = 0;
    var cards = carousel.querySelectorAll('.bt-pd-review-card');
    var total = cards.length;
    function getVisible() {
      return window.innerWidth <= 768 ? 1 : 3;
    }
    function update() {
      var visible = getVisible();
      var maxIndex = Math.max(0, total - visible);
      if (current > maxIndex) current = maxIndex;
      var cardWidth = carousel.parentElement.offsetWidth / visible;
      carousel.style.transform = 'translateX(-' + (current * cardWidth) + 'px)';
      cards.forEach(function(c) { c.style.minWidth = cardWidth - 20 + 'px'; });
    }
    prevBtn.addEventListener('click', function() { if (current > 0) { current--; update(); } });
    nextBtn.addEventListener('click', function() {
      var visible = getVisible();
      if (current < total - visible) { current++; update(); }
    });
    window.addEventListener('resize', update);
    update();
  }
})();
</script>

