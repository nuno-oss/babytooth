<script>
  function scrollReviews(sectionId, direction) {
    const carousel = document.getElementById('reviewsCarousel-' + sectionId);
    const scrollAmount = 380; // card width + gap
    carousel.scrollLeft += direction * scrollAmount;
    updateReviewDots(sectionId);
  }

  function updateReviewDots(sectionId) {
    const carousel = document.getElementById('reviewsCarousel-' + sectionId);
    const dotsContainer = document.getElementById('reviewsDots-' + sectionId);
    const cards = carousel.querySelectorAll('.review-card');
    const visibleCards = 3;
    const totalPages = Math.ceil(cards.length / visibleCards);

    dotsContainer.innerHTML = '';

    for (let i = 0; i < totalPages; i++) {
      const dot = document.createElement('div');
      dot.className = 'review-dot';
      if (i === 0) dot.classList.add('active');
      dotsContainer.appendChild(dot);
    }
  }

  function toggleFaq(element) {
    const faqItem = element.parentElement;
    faqItem.classList.toggle('active');
  }

  // Initialize review carousel dots
  document.addEventListener('DOMContentLoaded', function() {
    updateReviewDots('{{ section.id }}');
  });
</script>

