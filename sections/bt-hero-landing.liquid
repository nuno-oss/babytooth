<!-- Baby Tooth — Hero Landing Section -->
<script src="https://cdn.tailwindcss.com"></script>
<script>
  tailwind.config = {
    theme: {
      extend: {
        colors: {
          brand: {
            primary:    '#4D9BCB',
            accent:     '#3F8FBE',
            bg:         '#F3F8FC',
            text:       '#1A2D3D',
            secondary:  '#EDF2F7',
            mint:       '#7BCFB8',
            yellow:     '#F9E97E',
          }
        },
        fontFamily: {
          sans: ['"Nunito"', 'ui-rounded', 'system-ui', 'sans-serif'],
        }
      }
    }
  }
</script>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700;800;900&display=swap" rel="stylesheet">

<div id="bt-hero-{{ section.id }}" class="font-sans bg-brand-bg text-brand-text">

  <!-- ── Announcement Bar ── -->
  <div class="bg-brand-primary text-white text-center text-sm font-semibold py-2 px-4">
    {{ section.settings.announcement_text }}
  </div>

  <!-- ── Navigation ── -->
  <nav class="bg-white shadow-sm sticky top-0 z-50">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 py-3 flex items-center justify-between">
      <a href="/" class="flex items-center gap-2 no-underline">
        <span class="text-2xl font-black text-brand-primary tracking-tight">🦷 Baby Tooth</span>
      </a>
      <div class="hidden md:flex items-center gap-6 text-sm font-semibold text-brand-text">
        <a href="{{ section.settings.button_link }}" class="hover:text-brand-primary transition-colors no-underline">Shop</a>
      </div>
    </div>
  </nav>

  <!-- ── Hero Block ── -->
  <section class="max-w-6xl mx-auto px-4 sm:px-6 py-12 md:py-20">
    <div class="grid md:grid-cols-2 gap-10 items-center">

      <!-- Left: Copy -->
      <div class="flex flex-col gap-5">

        <!-- Social proof pill -->
        <div class="inline-flex items-center gap-2 bg-brand-secondary rounded-full px-4 py-2 text-sm font-semibold text-brand-text w-fit">
          <span class="text-yellow-400">★★★★★</span>
          <span>4.97/5 · 5,000+ happy moms · Ages 2–12</span>
        </div>

        <!-- Headline -->
        <h1 class="text-4xl md:text-5xl font-black leading-tight text-brand-text">
          {{ section.settings.heading }}
        </h1>

        <!-- Subtext -->
        <p class="text-lg text-gray-600 leading-relaxed">
          {{ section.settings.subheading }}
        </p>

        <!-- CTA Buttons -->
        <div class="flex flex-col sm:flex-row gap-3 mt-2">
          <a href="{{ section.settings.button_link }}"
             class="inline-block bg-brand-primary hover:bg-brand-accent text-white font-bold text-lg px-8 py-4 rounded-full text-center transition-all shadow-lg hover:shadow-xl hover:-translate-y-0.5 no-underline">
            {{ section.settings.button_label }}
          </a>
          <a href="{{ section.settings.secondary_button_link | default: '#' }}"
             class="inline-block border-2 border-brand-primary text-brand-primary hover:bg-brand-primary hover:text-white font-bold text-lg px-8 py-4 rounded-full text-center transition-all no-underline">
            {{ section.settings.secondary_button_label }}
          </a>
        </div>

        <!-- Trust badges -->
        <div class="flex flex-wrap gap-4 mt-2 text-sm font-semibold text-gray-600">
          <span class="flex items-center gap-1">✅ Free Shipping</span>
          <span class="flex items-center gap-1">✅ 30-Day Guarantee</span>
          <span class="flex items-center gap-1">✅ Dentist Recommended</span>
        </div>
      </div>

      <!-- Right: Hero Image -->
      <div class="relative flex justify-center">
        {% if section.settings.hero_image != blank %}
          {{ section.settings.hero_image | image_url: width: 800 | image_tag:
            class: 'w-full max-w-md rounded-3xl shadow-2xl object-cover',
            alt: section.settings.heading,
            loading: 'eager' }}
        {% else %}
          <div class="w-full max-w-md aspect-square bg-brand-secondary rounded-3xl flex flex-col items-center justify-center text-brand-primary opacity-60">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-24 h-24 mb-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
            </svg>
            <p class="text-sm font-semibold">Add hero image in Customizer</p>
          </div>
        {% endif %}

        <!-- Floating badge -->
        <div class="absolute -bottom-4 -left-4 bg-white rounded-2xl shadow-xl px-4 py-3 text-center hidden md:block">
          <div class="text-2xl font-black text-brand-primary">60s</div>
          <div class="text-xs font-semibold text-gray-500 leading-tight">All teeth<br>cleaned</div>
        </div>
      </div>

    </div>
  </section>

  <!-- ── Feature Icons Row ── -->
  <section class="bg-white py-10 border-y border-brand-secondary">
    <div class="max-w-4xl mx-auto px-4 sm:px-6">
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-6 text-center">

        <div class="flex flex-col items-center gap-3 p-4">
          <div class="w-14 h-14 bg-brand-bg rounded-full flex items-center justify-center text-3xl">🦷</div>
          <h3 class="font-bold text-brand-text">360° Clean in Seconds</h3>
          <p class="text-sm text-gray-500">U-shape wraps every tooth — front, back, and sides at once.</p>
        </div>

        <div class="flex flex-col items-center gap-3 p-4 border-y sm:border-y-0 sm:border-x border-brand-secondary">
          <div class="w-14 h-14 bg-brand-bg rounded-full flex items-center justify-center text-3xl">👨‍⚕️</div>
          <h3 class="font-bold text-brand-text">Dentist Approved</h3>
          <p class="text-sm text-gray-500">Medical-grade silicone. BPA-free. Pediatric-dentist recommended.</p>
        </div>

        <div class="flex flex-col items-center gap-3 p-4">
          <div class="w-14 h-14 bg-brand-bg rounded-full flex items-center justify-center text-3xl">⚡</div>
          <h3 class="font-bold text-brand-text">Kids Actually Love It</h3>
          <p class="text-sm text-gray-500">Cute animal design + gentle vibrations = a brush they beg to use.</p>
        </div>

      </div>
    </div>
  </section>

  <!-- ── Product Strip ── -->
  <section class="max-w-6xl mx-auto px-4 sm:px-6 py-14">
    <h2 class="text-3xl font-black text-center text-brand-text mb-2">
      Choose What's Right for Your Child
    </h2>
    <p class="text-center text-gray-500 mb-10">Available for ages 2–6 and 6–12. Multiple fun colors!</p>

    <div class="grid sm:grid-cols-2 gap-6 max-w-3xl mx-auto">

      <!-- Product 1 -->
      <div class="bg-white rounded-3xl shadow-md overflow-hidden flex flex-col transition-shadow hover:shadow-xl">
        {% if section.settings.product_image_1 != blank %}
          {{ section.settings.product_image_1 | image_url: width: 600 | image_tag:
            class: 'w-full aspect-square object-cover',
            alt: section.settings.product_name_1 }}
        {% else %}
          <div class="w-full aspect-square bg-brand-secondary flex items-center justify-center text-5xl">🪥</div>
        {% endif %}
        <div class="p-5 flex flex-col gap-3 flex-1">
          <h3 class="font-bold text-lg text-brand-text">{{ section.settings.product_name_1 }}</h3>
          <p class="text-brand-primary font-black text-xl">{{ section.settings.product_price_1 }}</p>
          <a href="{{ section.settings.product_link_1 }}"
             class="mt-auto bg-brand-primary hover:bg-brand-accent text-white font-bold py-3 px-6 rounded-full text-center transition-colors no-underline">
            Add to Cart
          </a>
        </div>
      </div>

      <!-- Product 2 -->
      <div class="bg-white rounded-3xl shadow-md overflow-hidden flex flex-col transition-shadow hover:shadow-xl">
        {% if section.settings.product_image_2 != blank %}
          {{ section.settings.product_image_2 | image_url: width: 600 | image_tag:
            class: 'w-full aspect-square object-cover',
            alt: section.settings.product_name_2 }}
        {% else %}
          <div class="w-full aspect-square bg-brand-secondary flex items-center justify-center text-5xl">🔄</div>
        {% endif %}
        <div class="p-5 flex flex-col gap-3 flex-1">
          <h3 class="font-bold text-lg text-brand-text">{{ section.settings.product_name_2 }}</h3>
          <p class="text-brand-primary font-black text-xl">{{ section.settings.product_price_2 }}</p>
          <a href="{{ section.settings.product_link_2 }}"
             class="mt-auto bg-brand-primary hover:bg-brand-accent text-white font-bold py-3 px-6 rounded-full text-center transition-colors no-underline">
            Add to Cart
          </a>
        </div>
      </div>

    </div>
  </section>

  <!-- ── Bottom CTA Strip ── -->
  <section class="bg-brand-primary py-14 text-white text-center px-4">
    <p class="text-sm font-semibold uppercase tracking-widest mb-3 opacity-80">Join 5,000+ Happy Families</p>
    <h2 class="text-3xl md:text-4xl font-black mb-4 leading-tight">
      Tonight Could Be the Last Night<br>You Fight Over Brushing
    </h2>
    <p class="text-lg opacity-90 mb-8 max-w-xl mx-auto">
      5,000+ moms already made the switch. Their kids are brushing happily. Their evenings are peaceful. You deserve that too.
    </p>
    <a href="{{ section.settings.button_link }}"
       class="inline-block bg-white text-brand-primary font-black text-lg px-10 py-4 rounded-full hover:bg-brand-bg transition-colors shadow-lg no-underline">
      {{ section.settings.button_label }}
    </a>
    <p class="mt-4 text-sm opacity-75">Free Shipping · 30-Day Guarantee · Your Sanity is Worth It</p>
  </section>

</div>

{% schema %}
{
  "name": "BT Hero Landing",
  "tag": "section",
  "class": "bt-hero-landing",
  "settings": [
    {
      "type": "header",
      "content": "Announcement Bar"
    },
    {
      "type": "text",
      "id": "announcement_text",
      "label": "Announcement Text",
      "default": "🚚 FREE Shipping Today + 30-Day Money-Back Guarantee"
    },
    {
      "type": "header",
      "content": "Hero Content"
    },
    {
      "type": "image_picker",
      "id": "hero_image",
      "label": "Hero Image"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Headline",
      "default": "\"Mommy, I Want to Brush My Teeth!\""
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Imagine your child running to the bathroom, excited to brush. No more tears. No more chasing. No more guilt. Baby Tooth makes it happen in 60 seconds flat."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Primary Button Label",
      "default": "Yes, I Need This!"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Primary Button Link"
    },
    {
      "type": "text",
      "id": "secondary_button_label",
      "label": "Secondary Button Label",
      "default": "See How It Works"
    },
    {
      "type": "url",
      "id": "secondary_button_link",
      "label": "Secondary Button Link"
    },
    {
      "type": "header",
      "content": "Product 1"
    },
    {
      "type": "image_picker",
      "id": "product_image_1",
      "label": "Product 1 Image"
    },
    {
      "type": "text",
      "id": "product_name_1",
      "label": "Product 1 Name",
      "default": "Kids Electric Toothbrush"
    },
    {
      "type": "text",
      "id": "product_price_1",
      "label": "Product 1 Price",
      "default": "EUR 24.99"
    },
    {
      "type": "url",
      "id": "product_link_1",
      "label": "Product 1 Link"
    },
    {
      "type": "header",
      "content": "Product 2"
    },
    {
      "type": "image_picker",
      "id": "product_image_2",
      "label": "Product 2 Image"
    },
    {
      "type": "text",
      "id": "product_name_2",
      "label": "Product 2 Name",
      "default": "Replacement Toothbrush Heads"
    },
    {
      "type": "text",
      "id": "product_price_2",
      "label": "Product 2 Price",
      "default": "EUR 9.70"
    },
    {
      "type": "url",
      "id": "product_link_2",
      "label": "Product 2 Link"
    }
  ],
  "presets": [
    {
      "name": "BT Hero Landing"
    }
  ]
}
{% endschema %}
